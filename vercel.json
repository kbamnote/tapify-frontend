{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/admin/(.*)",
            "destination": "/admin/$1"
        },
        {
            "source": "/dashboard/(.*)",
            "destination": "/dashboard/$1"
        },
        {
            "source": "/:slug",
            "destination": "/vcard.html"
        }
    ]
}