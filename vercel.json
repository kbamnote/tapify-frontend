{
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/admin/login",
            "destination": "/login",
            "permanent": false
        },
        {
            "source": "/admin",
            "destination": "/login",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/:slug((?!admin|dashboard|login|index|vcard-templates|webstore|images|templates|webStore_templates).*)",
            "destination": "/vcard.html"
        }
    ]
}